FROM node:24.14-alpine AS development
RUN corepack enable && corepack prepare pnpm@11.9.0 --activate
WORKDIR /app
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile
COPY . .
EXPOSE 5173
CMD ["pnpm", "dev", "--host", "0.0.0.0"]

FROM development AS build
ARG VITE_API_BASE_URL=""
ARG VITE_MAP_STYLE_URL=""
ARG VITE_MAP_TILE_URL=""
ARG VITE_MAP_PROVIDER_ID=""
ARG VITE_MAP_PROVIDER_NAME=""
ARG VITE_MAP_ATTRIBUTION_TEXT=""
ARG VITE_MAP_ATTRIBUTION_URL=""
ARG VITE_MAP_LICENSE_NAME=""
ARG VITE_MAP_LICENSE_URL=""
ARG VITE_MAP_TERMS_URL=""
ARG VITE_MAP_PRIVACY_URL=""
ARG VITE_MAP_REPORT_ISSUE_URL=""
ARG VITE_MAP_CONTACT_URL=""
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL} \
    VITE_MAP_STYLE_URL=${VITE_MAP_STYLE_URL} \
    VITE_MAP_TILE_URL=${VITE_MAP_TILE_URL} \
    VITE_MAP_PROVIDER_ID=${VITE_MAP_PROVIDER_ID} \
    VITE_MAP_PROVIDER_NAME=${VITE_MAP_PROVIDER_NAME} \
    VITE_MAP_ATTRIBUTION_TEXT=${VITE_MAP_ATTRIBUTION_TEXT} \
    VITE_MAP_ATTRIBUTION_URL=${VITE_MAP_ATTRIBUTION_URL} \
    VITE_MAP_LICENSE_NAME=${VITE_MAP_LICENSE_NAME} \
    VITE_MAP_LICENSE_URL=${VITE_MAP_LICENSE_URL} \
    VITE_MAP_TERMS_URL=${VITE_MAP_TERMS_URL} \
    VITE_MAP_PRIVACY_URL=${VITE_MAP_PRIVACY_URL} \
    VITE_MAP_REPORT_ISSUE_URL=${VITE_MAP_REPORT_ISSUE_URL} \
    VITE_MAP_CONTACT_URL=${VITE_MAP_CONTACT_URL}
RUN pnpm build
RUN mkdir -p dist/third-party \
    && cp node_modules/maplibre-gl/LICENSE.txt dist/third-party/maplibre-gl-LICENSE.txt

FROM nginx:1.29-alpine AS production
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
